{
  "compilerOptions": {
    "target": "ES2021",
    "module": "NodeNext",
    "moduleResolution": "nodenext",

    "types": ["node", "@playwright/test"],

    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "outDir": "dist",
    "rootDir": "."
  },

  "include": [
    "src",
    "tests",
    "pages",
    "utils",
    "playwright.config.ts"
  ],

  "exclude": [
    "node_modules"
  ]
}